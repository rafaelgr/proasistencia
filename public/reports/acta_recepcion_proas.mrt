              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<font size=\"14\"><b>ACTA DE RECEPCIÓN DE OBRA</b></font>"
              },
              "HorAlignment": "Center",
              "Font": "Tahoma;14;Bold;",
              "Border": ";;;;;;;solid:31,78,121",
              "Brush": "solid:245,248,252",
              "TextBrush": "solid:31,78,121",
              "AllowHtmlTags": true,
              "Type": "Expression"
            },
            "1": {
              "Ident": "StiText",
              "Name": "Text18",
              "ClientRectangle": "0.2,0.95,17.4,0.95",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"font-family: Tahoma; text-align: right;\">\n  <font size=\"9\">\n    <font face=\"Tahoma\">\n      <font style=\"letter-spacing: -0.133333px;\">\n        <span style=\"white-space: pre;\">\t\t\t\t\t\t\t\t\t</span>&nbsp; En Madrid a</font><span style=\"letter-spacing: -0.133333px;\">&nbsp;</span><span style=\"letter-spacing: -0.133333px;\">{datos_contrato.fechaActual}</span>\n    </font>\n  </font>\n</div>\n\n<div style=\"font-family: Tahoma; text-align: justify;\">\n  <font size=\"9\">\n    <span style=\"letter-spacing: -0.133333px;\">\n      <font face=\"Tahoma\"><b>DATOS DE LA OBRA</b></font>\n    </span>\n  </font>\n</div>\n\n<div style=\"font-family: Tahoma; text-align: justify;\">\n  <font size=\"9\">\n    <span style=\"letter-spacing: -0.133333px;\"><br></span>\n  </font>\n</div>\n\n<div style=\"font-family: Tahoma; text-align: justify;\"><br></div>\n"
              },
              "HorAlignment": "Right",
              "Font": "Tahoma;9;;",
              "Border": ";;;;;;;solid:205,214,224",
              "Brush": "solid:245,248,252",
              "TextBrush": "solid:31,78,121",
              "AllowHtmlTags": true,
              "Type": "Expression"
            },
            "2": {
              "Ident": "StiText",
              "Name": "Text8",
              "ClientRectangle": "0.35,2.05,17.2,3.6",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "  Dirección obra:        {datos_contrato.direccionTrabajo}  \n  Trabajos realizados:  {datos_contrato.tituloExpediente}\n\n  Ref. presupuesto:    {datos_contrato.referencia} \n  Certificación final      {datos_contrato.certificacionFinal} € sin IVA\n  Fecha de contrato de ejecución de obras:    {datos_contrato.fechaInicio} \n  Saldo pendiente de abono al día de la fecha: {datos_contrato.totalPendienteFacturar} €  IVA INCLUIDO\n  El abono del saldo pendiente se realizará mediante:"
              },
              "HorAlignment": "Width",
              "Font": "Tahoma;9;;",
              "Border": ";;;;;;;solid:205,214,224",
              "Brush": "solid:252,252,252",
              "TextBrush": "solid:45,45,45",
              "LineSpacing": 1.15,
              "Type": "Expression"
            }
          },
          "CanGrow": false,
          "DataSourceName": "datos_contrato"
        },
