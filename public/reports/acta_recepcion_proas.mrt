                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "REUNIDOS\n"
              },
              "Font": "Tahoma;10;Bold;",
              "Border": ";;;;;;;solid:205,214,224",
              "Brush": "solid:245,248,252",
              "TextBrush": "solid:31,78,121",
              "Type": "Expression"
            },
            "1": {
              "Ident": "StiText",
              "Name": "Text14",
              "Guid": "2bfb2bdc5712a317373a238b8248cfc2",
              "ClientRectangle": "9.15,0.75,8.45,2.85",
              "Expressions": {
                "0": {
                  "Name": "Font"
                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<p style=\"font-family: Tahoma; margin: 0px 0px 6pt;\">\n  <font size=\"9\">&nbsp;&nbsp;<u>LA PROPIEDAD</u></font>\n</p><p style=\"font-family: Tahoma; margin: 0px 0px 6pt;\"><br></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 6pt;\">\n  <font size=\"9\">&nbsp; Cliente:&nbsp; &nbsp;{datos_contrato.nombreCliente}</font>\n</p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\">\n  <font size=\"9\">&nbsp; Nombre: {datos_contrato.nombreFirmante}</font>\n</p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\">\n  <font size=\"9\">&nbsp; Cargo:&nbsp; &nbsp; PRESIDENTE</font>\n</p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\">\n  <font size=\"9\">&nbsp; Cuenta Bancaria: {datos_contrato.iban}</font>\n</p>\n\n"
              },
              "HorAlignment": "Width",
              "Font": "Tahoma;9;;",
              "Border": ";;;;;;;solid:205,214,224",
              "Brush": "solid:252,252,252",
              "TextBrush": "solid:45,45,45",
              "TextOptions": {
                "WordWrap": true
              },
              "TextQuality": "Wysiwyg",
              "AllowHtmlTags": true,
              "Type": "Expression"
            },
            "2": {
              "Ident": "StiText",
              "Name": "Text15",
              "Guid": "9bc9cb0d9ff1405720eea90877410a77",
              "ClientRectangle": "0.35,0.75,8.45,2.85",
              "Expressions": {
                "0": {
                  "Name": "Font"
                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<p style=\"font-family: Tahoma; margin: 0px 0px 6pt;\"><font size=\"9\">\n  &nbsp; <u style=\"\">LA CONTRATA</u>&nbsp; &nbsp; &nbsp;</font></p><p style=\"font-family: Tahoma; margin: 0px 0px 6pt;\"><font size=\"10\">&nbsp;</font></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\"><font size=\"9\">\n  &nbsp; Nombre:&nbsp; Proasistencia S.L.\n</font></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\"><font size=\"9\">\n  &nbsp; Representante: ADELA ALONSO AGARCIA\n</font></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\"><font size=\"9\">\n  &nbsp; Domicilio: C/ Camino de Rejas 1, Coslada, 28821. Madrid\n</font></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\"><font size=\"9\">\n  &nbsp; CIF:&nbsp; &nbsp; &nbsp; &nbsp; &nbsp;B81323180\n</font></p>\n\n<p style=\"font-family: Tahoma; margin: 0px 0px 12pt;\"><font size=\"9\">\n  &nbsp; e‐mail:&nbsp; &nbsp; &nbsp;administracion@proasistencia.es\n</font></p>\n\n"
              },
              "HorAlignment": "Width",
              "Font": "Tahoma;9;;",
              "Border": ";;;;;;;solid:205,214,224",
              "Brush": "solid:252,252,252",
              "TextBrush": "solid:45,45,45",
              "TextOptions": {
                "WordWrap": true
              },
              "TextQuality": "Wysiwyg",
              "AllowHtmlTags": true,
              "Type": "Expression"
            }
          },
          "Columns": 2
        },
        "8": {
          "Ident": "StiDataBand",
          "Name": "DataBand6",
          "Guid": "f409c93f1e34bf66a8fd8eb7ba3ca0ed",
          "CanGrow": true,
          "ClientRectangle": "0,16.45,18,1.4",
          "Expressions": {
            "0": {
              "Name": "CountData"
