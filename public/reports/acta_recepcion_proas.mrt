          },
          "Interaction": {
            "Ident": "StiBandInteraction"
          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text11",
              "Guid": "7741c03ceaac922f0cf5ca1fb97d75c3",
              "ClientRectangle": "0.4,-0.05,17.4,1.4",
              "Expressions": {
                "0": {
                  "Name": "Font"
                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"\">\n  <div style=\"font-family: Tahoma; line-height: 1.1; text-align: justify;\"><font size=\"9\">\n    <font face=\"Tahoma\">\n      Reunidos en Madrid, la empresa adjudicataria de las obras y la propiedad de la finca de referencia, para dar&nbsp;\n    </font>\n    <span style=\"font-family: Tahoma;\">\n      cumplimiento a lo dispuesto en el contrato suscrito por ambas partes, una vez finalizadas las mismas, recorrido a su&nbsp;\n    </span>\n    <span style=\"font-family: Tahoma;\">\n      ámbito de actuación para comprobar su terminación y en base al seguimiento realizado durante su ejecución.</span></font></div>\n</div>\n\n"
              },
              "Font": "Tahoma;9;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:",
              "TextBrush": "solid:45,45,45",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "ShrinkFontToFitMinimumSize": 1.1,
              "LineSpacing": 1.2,
              "Type": "Expression"
            }
          }
        },
