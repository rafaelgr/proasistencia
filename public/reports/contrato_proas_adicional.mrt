              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"\"><font style=\"\" face=\"Tahoma\" size=\"10\"><font style=\"\">A LA FIRMA de la obra&nbsp;</font>&nbsp;<font style=\"\">se entregarán&nbsp;</font><font style=\"\">las siguientes&nbsp;</font>letras de&nbsp;cambio que se relacionan, incluyendo IVA e intereses:</font></div>"
              },
              "HorAlignment": "Width",
              "Font": "Tahoma;10;;",
              "Border": ";;;;;;;solid:0,0,0",
