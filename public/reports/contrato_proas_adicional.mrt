              "ClientRectangle": "11,3.42,6.2,0.4",
              "Expressions": {
                "0": {
                  "Name": "Font"
                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<font size=\"10\" style=\"\" face=\"Tahoma\">Fdo.Mª Adela Alonso García</font>"
              },
              "Font": ";10;;",
              "Border": ";;;;;;;solid:Black",
              "Brush": "solid:",
              "TextBrush": "solid:Black",
              "AllowHtmlTags": true,
