          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text1",
              "Guid": "4a94dca6b858764119b30db5cc1d3ffa",
              "CanGrow": true,
              "GrowToHeight": true,
              "ClientRectangle": "0.6,0.25,16.8,0.4",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<ul>\n<li>\n      {datos_contrato_letras_narrativa.textoNarrativa}\n</li>\n</ul>"
              },
              "HorAlignment": "Width",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "Margins": {
