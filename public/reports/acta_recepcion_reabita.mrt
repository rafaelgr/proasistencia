              "Name": "Text7",
              "Guid": "07c0c5a3ddb1404add8e5457690f23c7",
              "ClientRectangle": "0.6,0.2,6.4,0.5",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "POR LA EMPRESA ADJUDICATARIA"
              },
              "Font": ";10;Bold;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "AllowHtmlTags": true,
              "Type": "Expression"
            },
            "3": {
              "Ident": "StiText",
              "Name": "Text6",
              "Guid": "d51f9e5a9451927f5e6588bc02a9b8f9",
              "ClientRectangle": "0.6,3.34,7.4,0.4",
              "Expressions": {
                "0": {
                  "Name": "Font"
                }
              },
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"\"><font face=\"Tahoma\">Fdo.: Mª Dolores Gómez Martín&nbsp; &nbsp; &nbsp;</font></div>"
              },
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "AllowHtmlTags": true,
              "Type": "Expression"
            }
          }
        },
        "2": {
          "Ident": "StiDataBand",
          "Name": "DataBand1",
          "CanGrow": true,
          "ClientRectangle": "0,0.4,18.2,4.95",
          "Interaction": {
            "Ident": "StiBandInteraction"
          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text18",
              "CanGrow": true,
              "GrowToHeight": true,
              "ClientRectangle": "0.6,0.75,16.8,1.05",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"font-family: Tahoma; text-align:right; margin-top: 4pt;\"><font size=\"10\">Madrid, {datos_contrato.fechaActual}</font></div>\n\n<div style=\"font-family: Tahoma; text-align:justify; line-height:1.2;\"><font size=\"10\"><b>OBRA. - </b>{datos_contrato.tituloExpediente} en la comunidad de propietarios&nbsp; {datos_contrato.direccionTrabajo}</font></div>"
              },
              "HorAlignment": "Right",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "Type": "Expression"
            },
            "1": {
              "Ident": "StiText",
              "Name": "Text8",
              "CanGrow": true,
              "GrowToHeight": true,
              "ClientRectangle": "0.6,2,16.8,2.65",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"font-family: Tahoma; text-align:justify; line-height:1.18;\"><font size=\"10\">Reunidos en Madrid, D.ª M.ª DOLORES GOMEZ MARTIN, como representante de <b>REABITA OBRAS DE REHABILITACION S.L.</b>, empresa adjudicataria de las mismas, y {datos_contrato.nombreFirmante}, en representación de {datos_contrato.nombreCliente}, para dar cumplimiento a lo dispuesto en el contrato suscrito por ambas partes el día {datos_contrato.fechaInicio}, una vez finalizadas las mismas, recorrido su ámbito de actuación para comprobar su terminación y en base al seguimiento realizado durante su ejecución,</font></div>"
              },
              "HorAlignment": "Width",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "LineSpacing": 1.15,
              "Type": "Expression"
            },
            "2": {
              "Ident": "StiText",
              "Name": "Text9",
              "Guid": "35052808a12da06cfe6f1422b24d23af",
              "ClientRectangle": "0.6,0,16.8,0.65",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<b style=\"text-align: center;\"><font size=\"14\">ACTA DE RECEPCIÓN DE OBRA</font></b>"
              },
              "HorAlignment": "Center",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "AllowHtmlTags": true,
              "Type": "Expression"
            }
          },
          "DataSourceName": "datos_contrato"
        },
        "3": {
          "Ident": "StiDataBand",
          "Name": "DataBand2",
          "CanGrow": true,
          "ClientRectangle": "0,6.15,18.2,0.8",
          "Expressions": {
            "0": {
              "Name": "CountData"
            }
          },
          "Interaction": {
            "Ident": "StiBandInteraction"
          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text4",
              "Guid": "5239cf4047ee4b311ee5c2a653f29052",
              "CanShrink": true,
              "CanGrow": true,
              "GrowToHeight": true,
              "MinSize": "0,0.1",
              "ClientRectangle": "0.6,0.05,16.8,0.65",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<div style=\"font-family: Tahoma; text-align:left;\"><b style=\"\"><font size=\"10\">EXPONEN:</font></b></div>"
              },
              "VertAlignment": "Center",
              "Font": ";11;Bold;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "AllowHtmlTags": true,
              "LineSpacing": 1.2,
              "Type": "Expression"
            }
          }
        },
        "4": {
          "Ident": "StiDataBand",
          "Name": "DataBand5",
          "Guid": "9c6b814bf3a6f22b303ffb2fc6bb1abe",
          "CanGrow": true,
          "ClientRectangle": "0,7.75,18.2,2",
          "Expressions": {
            "0": {
              "Name": "CountData"
            }
          },
          "Interaction": {
            "Ident": "StiBandInteraction"
          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text10",
              "Guid": "80120f415a17f4e2943b2d44a92086f1",
              "CanGrow": true,
              "GrowToHeight": true,
              "ClientRectangle": "0.6,0.05,16.8,1.55",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<ol>\n  <li>\n    Que las obras correspondientes a {datos_contrato.tituloExpediente}, con referencia de presupuesto {datos_contrato.referencia}, ascienden, según certificación final de obra, a un importe de {datos_contrato.certificacionFinal} € más IVA, quedando pendiente por abonar la Propiedad a la Contrata al día de la fecha la cantidad de {datos_contrato.totalPendienteFacturar} € IVA INCLUIDO, según se detalla:</li></ol>"
              },
              "HorAlignment": "Width",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "ShrinkFontToFitMinimumSize": 1.1,
              "LineSpacing": 1.2,
              "Type": "Expression"
            }
          }
        },
        "5": {
          "Ident": "StiDataBand",
          "Name": "DataBand4",
          "Guid": "40e9a952069a8db703d91b6de5692ae7",
          "CanShrink": true,
          "ClientRectangle": "0,10.55,18.2,0.85",
          "Interaction": {
            "Ident": "StiBandInteraction"
          },
          "Border": ";;;;;;;solid:Black",
          "Brush": "solid:",
          "Components": {
            "0": {
              "Ident": "StiText",
              "Name": "Text12",
              "Guid": "765765e099fa4da102e762b65b43ac8f",
              "CanGrow": true,
              "GrowToHeight": true,
              "ClientRectangle": "0.6,0.25,16.8,0.4",
              "Interaction": {
                "Ident": "StiInteraction"
              },
              "Text": {
                "Value": "<ul>\n<li>\nFactura de {datos_contrato_pagos.importePrefacturadoIva} € incluido IVA con fecha {datos_contrato_pagos.fecvenci}\n</li>\n</ul>\n"
              },
              "HorAlignment": "Width",
              "Font": ";10;;",
              "Border": ";;;;;;;solid:255,255,255",
              "Brush": "solid:255,255,255",
              "TextBrush": "solid:0,0,0",
              "TextOptions": {
                "WordWrap": true
              },
              "AllowHtmlTags": true,
              "Margins": {
                "Left": 17,
                "Right": 0,
                "Top": 0,
                "Bottom": 0
              },
              "LineSpacing": 1.15,
              "Type": "Expression"
            }
          },
          "CanGrow": false,
          "MinHeight": 0.1,
          "DataSourceName": "datos_contrato_pagos",
          "DataRelationName": "pagos_contrato"
        },
