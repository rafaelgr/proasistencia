          "Ident": "StiGroupHeaderBand",
          "Name": "GroupHeaderBand1",
          "Guid": "1fa1bf38d102c9031aca9d28f5117a26",
          "CanGrow": true,
          "ClientRectangle": "0,12.2,18.2,0",
          "Interaction": {
